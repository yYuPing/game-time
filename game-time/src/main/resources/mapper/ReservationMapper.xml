<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuyu.game_time.mapper.ReservationMapper">

    <select id="findById" resultType="Reservation">
        SELECT * FROM reservations WHERE id = #{id}
    </select>

    <select id="findByDate" resultType="Reservation">
        SELECT * FROM reservations WHERE date = #{date}
    </select>

    <select id="findByDateBetween" resultType="Reservation">
        SELECT * FROM reservations WHERE date BETWEEN #{start} AND #{end}
    </select>

    <select id="findByUserId" resultType="Reservation">
        SELECT * FROM reservations WHERE user_id = #{userId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO reservations (user_id, username, date, timeslot, game_id, game_name, note, created_at)
        VALUES (#{userId}, #{username}, #{date}, #{timeslot}, #{gameId}, #{gameName}, #{note}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM reservations WHERE id = #{id}
    </delete>

    <update id="updateNote">
        UPDATE reservations SET note = #{note} WHERE id = #{id}
    </update>

</mapper>
